{
  "manifest_version": 3,
  "name": "Twimark: Twitter Bookmark & AI Exporter",
  "version": "2.1",
  "description": "Export X/Twitter bookmarks to CSV or NotebookLM (AI Ready) instantly.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}